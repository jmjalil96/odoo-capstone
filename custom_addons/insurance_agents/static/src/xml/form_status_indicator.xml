<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="insurance_agents.FormStatusIndicator" t-inherit="web.FormStatusIndicator" t-inherit-mode="extension">
        <xpath expr="//button[hasclass('o_form_button_save')]/i" position="after">
            <span
                t-if="props.model.root.resModel === 'insurance.agent'"
                class="d-none d-lg-inline ms-1">
                Guardar
            </span>
        </xpath>
        <xpath expr="//button[hasclass('o_form_button_cancel')]/i" position="after">
            <span
                t-if="props.model.root.resModel === 'insurance.agent'"
                class="d-none d-lg-inline ms-1">
                Descartar
            </span>
        </xpath>
        <xpath expr="//div[hasclass('o_form_status_indicator_buttons')]" position="after">
            <span
                t-if="props.model.root.resModel === 'insurance.agent' and (props.model.root.isNew or displayButtons)"
                class="small text-muted ms-2">
                <t t-if="indicatorMode === 'invalid'">Revisa los campos obligatorios</t>
                <t t-elif="props.model.root.isNew">Agente nuevo sin guardar</t>
                <t t-else="">Cambios sin guardar</t>
            </span>
        </xpath>
    </t>
</templates>
