<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_insurance_policy_list" model="ir.ui.view">
        <field name="name">insurance.policy.list</field>
        <field name="model">insurance.policy</field>
        <field name="arch" type="xml">
            <list string="Polizas" duplicate="0">
                <field name="policy_number" string="Numero de poliza"/>
                <field name="client_id" string="Cliente"/>
                <field name="area" string="Area"/>
                <field name="ramo" string="Ramo"/>
            </list>
        </field>
    </record>

    <record id="view_insurance_policy_form" model="ir.ui.view">
        <field name="name">insurance.policy.form</field>
        <field name="model">insurance.policy</field>
        <field name="arch" type="xml">
            <form string="Poliza" duplicate="0">
                <header>
                    <button name="action_new_term" string="Nueva vigencia" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <group string="Datos de poliza">
                        <group>
                            <field name="policy_number" string="Numero de poliza"/>
                            <field name="client_id" string="Cliente" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="area" string="Area"/>
                            <field name="ramo" string="Ramo"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Vigencias" name="terms">
                            <field name="term_ids" mode="list" context="{'default_policy_id': id, 'default_business_type': 'new'}">
                                <list string="Vigencias" create="0" edit="0" delete="0" no_open="1">
                                    <field name="business_type" string="Tipo" width="120px"/>
                                    <field name="state" string="Estado" widget="badge" width="120px" decoration-info="state == 'draft'" decoration-success="state == 'active'" decoration-warning="state == 'review'" decoration-danger="state == 'cancelled'"/>
                                    <field name="closure_reason" string="Cierre" optional="hide" width="180px"/>
                                    <field name="effective_date" string="Inicio" options="{'numeric': True}" width="110px"/>
                                    <field name="expiration_date" string="Fin" options="{'numeric': True}" width="110px"/>
                                    <button name="action_open_form" string="Abrir" title="Abrir vigencia" type="object" icon="fa-external-link" width="90px"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_insurance_policy_search" model="ir.ui.view">
        <field name="name">insurance.policy.search</field>
        <field name="model">insurance.policy</field>
        <field name="arch" type="xml">
            <search string="Polizas">
                <field name="policy_number" string="Numero de poliza"/>
                <field name="client_id" string="Cliente"/>
                <field name="area" string="Area"/>
                <field name="ramo" string="Ramo"/>
                <group name="group_by">
                    <filter name="group_client" string="Cliente" context="{'group_by': 'client_id'}"/>
                    <filter name="group_area" string="Area" context="{'group_by': 'area'}"/>
                    <filter name="group_ramo" string="Ramo" context="{'group_by': 'ramo'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_insurance_policy_term_list" model="ir.ui.view">
        <field name="name">insurance.policy.term.list</field>
        <field name="model">insurance.policy.term</field>
        <field name="arch" type="xml">
            <list string="Vigencias" duplicate="0">
                <field name="policy_id" string="Poliza"/>
                <field name="business_type" string="Tipo de negocio"/>
                <field name="state" string="Estado" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'active'" decoration-warning="state == 'review'" decoration-danger="state == 'cancelled'"/>
                <field name="closure_reason" string="Motivo de cierre" optional="hide"/>
                <field name="effective_date" string="Fecha de vigencia" options="{'numeric': True}"/>
                <field name="expiration_date" string="Fecha de vencimiento" options="{'numeric': True}"/>
            </list>
        </field>
    </record>

    <record id="view_insurance_policy_term_form" model="ir.ui.view">
        <field name="name">insurance.policy.term.form</field>
        <field name="model">insurance.policy.term</field>
        <field name="arch" type="xml">
            <form string="Vigencia" duplicate="0">
                <header>
                    <button name="action_confirm_emission" string="Emision Confirmada" type="object" class="btn-primary" invisible="state != 'draft'" confirm="Confirmar emision de esta vigencia?"/>
                    <button name="action_cancel_emission" string="Emision Cancelada" type="object" invisible="state != 'draft'" confirm="Cancelar esta emision? La vigencia quedara cancelada."/>
                    <button name="action_send_to_review" string="Fin de Vigencia o Cancelacion" type="object" class="btn-primary" invisible="state != 'active'" confirm="Enviar esta vigencia a revision por fin de vigencia o cancelacion?"/>
                    <button name="action_mark_renewed" string="Poliza Renovada" type="object" class="btn-primary" invisible="state != 'review'" confirm="Marcar esta vigencia como renovada y cerrarla?"/>
                    <button name="action_cancel_unpaid" string="Poliza Cancelada sin Pago" type="object" invisible="state != 'review'" confirm="Marcar esta vigencia como cancelada sin pago?"/>
                    <button name="action_mark_lost" string="Poliza Perdida" type="object" invisible="state != 'review'" confirm="Marcar esta vigencia como perdida?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,review,cancelled"/>
                </header>
                <sheet>
                    <group string="Datos de vigencia">
                        <group>
                            <field name="policy_id" string="Poliza" options="{'no_create': True}"/>
                            <field name="business_type" string="Tipo de negocio"/>
                            <field name="state" string="Estado" widget="badge" readonly="1" decoration-info="state == 'draft'" decoration-success="state == 'active'" decoration-warning="state == 'review'" decoration-danger="state == 'cancelled'"/>
                            <field name="closure_reason" string="Motivo de cierre" readonly="1" invisible="state != 'cancelled'"/>
                        </group>
                        <group>
                            <field name="effective_date" string="Fecha de vigencia" options="{'numeric': True}"/>
                            <field name="expiration_date" string="Fecha de vencimiento" options="{'numeric': True}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_insurance_policy_term_search" model="ir.ui.view">
        <field name="name">insurance.policy.term.search</field>
        <field name="model">insurance.policy.term</field>
        <field name="arch" type="xml">
            <search string="Vigencias">
                <field name="policy_id" string="Poliza"/>
                <field name="business_type" string="Tipo de negocio"/>
                <field name="state" string="Estado"/>
                <field name="closure_reason" string="Motivo de cierre"/>
                <filter name="business_new" string="Nuevo" domain="[('business_type', '=', 'new')]"/>
                <filter name="business_renewal" string="Renovacion" domain="[('business_type', '=', 'renewal')]"/>
                <separator/>
                <filter name="state_draft" string="En Emision" domain="[('state', '=', 'draft')]"/>
                <filter name="state_active" string="Activas" domain="[('state', '=', 'active')]"/>
                <filter name="state_review" string="En Revision" domain="[('state', '=', 'review')]"/>
                <filter name="state_cancelled" string="Canceladas" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter name="closure_emission_cancelled" string="Emision cancelada" domain="[('closure_reason', '=', 'emission_cancelled')]"/>
                <filter name="closure_renewed" string="Renovadas" domain="[('closure_reason', '=', 'renewed')]"/>
                <filter name="closure_unpaid" string="Sin pago" domain="[('closure_reason', '=', 'unpaid')]"/>
                <filter name="closure_lost" string="Perdidas" domain="[('closure_reason', '=', 'lost')]"/>
                <group name="group_by">
                    <filter name="group_policy" string="Poliza" context="{'group_by': 'policy_id'}"/>
                    <filter name="group_state" string="Estado" context="{'group_by': 'state'}"/>
                    <filter name="group_closure_reason" string="Motivo de cierre" context="{'group_by': 'closure_reason'}"/>
                    <filter name="group_business_type" string="Tipo de negocio" context="{'group_by': 'business_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_insurance_policies" model="ir.actions.act_window">
        <field name="name">Polizas</field>
        <field name="res_model">insurance.policy</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0), (0, 0, {'view_mode': 'list', 'view_id': ref('view_insurance_policy_list')}), (0, 0, {'view_mode': 'form', 'view_id': ref('view_insurance_policy_form')})]"/>
        <field name="search_view_id" ref="view_insurance_policy_search"/>
    </record>

    <record id="action_insurance_policy_terms" model="ir.actions.act_window">
        <field name="name">Vigencias</field>
        <field name="res_model">insurance.policy.term</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0), (0, 0, {'view_mode': 'list', 'view_id': ref('view_insurance_policy_term_list')}), (0, 0, {'view_mode': 'form', 'view_id': ref('view_insurance_policy_term_form')})]"/>
        <field name="search_view_id" ref="view_insurance_policy_term_search"/>
    </record>

    <menuitem id="menu_insurance_policies" name="Polizas" parent="insurance_base.menu_insurance_root" action="action_insurance_policies" sequence="20"/>
</odoo>
