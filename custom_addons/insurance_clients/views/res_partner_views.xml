<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_insurance_client_list" model="ir.ui.view">
        <field name="name">insurance.client.list</field>
        <field name="model">insurance.client</field>
        <field name="arch" type="xml">
            <list string="Clientes" duplicate="0">
                <field name="name" string="Nombre para mostrar"/>
                <field name="company_type" string="Tipo de cliente"/>
                <field name="id_type" string="Tipo de identificacion"/>
                <field name="vat" string="Numero de identificacion"/>
                <field name="phone" string="Celular"/>
                <field name="email" string="Correo"/>
                <field name="city" string="Ciudad"/>
                <field name="user_id" string="Asesor" widget="many2one_avatar_user"/>
            </list>
        </field>
    </record>

    <record id="view_insurance_client_form" model="ir.ui.view">
        <field name="name">insurance.client.form</field>
        <field name="model">insurance.client</field>
        <field name="arch" type="xml">
            <form string="Cliente" duplicate="0">
                <sheet>
                    <field name="partner_id" invisible="1"/>
                    <field name="is_company" invisible="1"/>

                    <group>
                        <group>
                            <field name="company_type" string="Tipo de cliente" widget="radio" options="{'horizontal': true}"/>
                            <field name="name" string="Nombre para mostrar" readonly="not is_company" required="is_company"/>
                        </group>
                        <group>
                            <field name="user_id" string="Asesor" widget="many2one_avatar_user" domain="[('share', '=', False)]"/>
                        </group>
                    </group>

                    <group string="Identificacion">
                        <group>
                            <field name="id_type" string="Tipo de identificacion" required="1"/>
                        </group>
                        <group>
                            <field name="vat" string="Numero de identificacion" required="1"/>
                        </group>
                    </group>

                    <group string="Datos personales" invisible="is_company">
                        <group>
                            <field name="first_name" string="Nombres" required="not is_company"/>
                            <field name="last_name" string="Apellidos" required="not is_company"/>
                            <field name="gender" string="Sexo"/>
                        </group>
                        <group>
                            <field name="birthdate" string="Fecha de nacimiento" options="{'numeric': True}"/>
                            <field name="occupation" string="Ocupacion"/>
                        </group>
                    </group>

                    <group string="Datos corporativos" invisible="not is_company">
                        <group>
                            <field name="activity" string="Actividad"/>
                        </group>
                    </group>

                    <group string="Contacto">
                        <group>
                            <field name="phone" string="Celular"/>
                        </group>
                        <group>
                            <field name="email" string="Correo" widget="email"/>
                        </group>
                    </group>

                    <group string="Direccion principal">
                        <group>
                            <field name="street" string="Direccion"/>
                            <field name="street2" string="Direccion 2"/>
                            <field name="city" string="Ciudad"/>
                        </group>
                        <group>
                            <field name="state_id" string="Provincia" options="{'no_open': True, 'no_quick_create': True}" context="{'country_id': country_id, 'default_country_id': country_id}"/>
                            <field name="country_id" string="Pais" options="{'no_open': True, 'no_create': True}"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Contactos" name="corporate_contacts" invisible="not is_company">
                            <field name="child_ids" mode="list,form" domain="[('type', '=', 'contact')]" context="{'default_parent_id': partner_id, 'default_type': 'contact', 'default_user_id': user_id}">
                                <list editable="bottom" string="Contactos">
                                    <field name="type" invisible="1"/>
                                    <field name="name" string="Nombre"/>
                                    <field name="function" string="Cargo"/>
                                    <field name="email" string="Correo"/>
                                    <field name="phone" string="Celular"/>
                                </list>
                                <form string="Contacto corporativo">
                                    <sheet>
                                        <field name="type" invisible="1"/>
                                        <group>
                                            <field name="name" string="Nombre" required="1"/>
                                            <field name="function" string="Cargo"/>
                                            <field name="email" string="Correo" widget="email"/>
                                            <field name="phone" string="Celular"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Direcciones" name="addresses">
                            <field name="child_ids" mode="list,form" domain="[('type', 'in', ['invoice', 'delivery', 'other'])]" context="{'default_parent_id': partner_id, 'default_type': 'invoice', 'default_user_id': user_id}">
                                <list editable="bottom" string="Direcciones">
                                    <field name="type" string="Tipo"/>
                                    <field name="name" string="Etiqueta"/>
                                    <field name="street" string="Direccion"/>
                                    <field name="street2" string="Direccion 2"/>
                                    <field name="city" string="Ciudad"/>
                                    <field name="state_id" string="Provincia"/>
                                    <field name="country_id" string="Pais"/>
                                </list>
                                <form string="Direccion">
                                    <sheet>
                                        <group>
                                            <field name="type" string="Tipo" required="1"/>
                                            <field name="name" string="Etiqueta"/>
                                            <field name="street" string="Direccion"/>
                                            <field name="street2" string="Direccion 2"/>
                                            <field name="city" string="Ciudad"/>
                                            <field name="state_id" string="Provincia"/>
                                            <field name="country_id" string="Pais"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Auditoria" name="audit">
                            <group>
                                <group>
                                    <field name="create_uid" string="Creado por" readonly="1"/>
                                    <field name="create_date" string="Fecha de creacion" readonly="1" options="{'numeric': True}"/>
                                </group>
                                <group>
                                    <field name="write_uid" string="Modificado por" readonly="1"/>
                                    <field name="write_date" string="Fecha de modificacion" readonly="1" options="{'numeric': True}"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_insurance_client_search" model="ir.ui.view">
        <field name="name">insurance.client.search</field>
        <field name="model">insurance.client</field>
        <field name="arch" type="xml">
            <search string="Clientes">
                <field name="name" string="Nombre para mostrar"/>
                <field name="first_name" string="Nombres"/>
                <field name="last_name" string="Apellidos"/>
                <field name="vat" string="Numero de identificacion"/>
                <field name="phone" string="Celular"/>
                <field name="email" string="Correo"/>
                <field name="user_id" string="Asesor"/>
                <filter name="individuals" string="Individuales" domain="[('is_company', '=', False)]"/>
                <filter name="companies" string="Corporativos" domain="[('is_company', '=', True)]"/>
                <separator/>
                <filter name="missing_advisor" string="Sin asesor" domain="[('user_id', '=', False)]"/>
                <filter name="missing_email" string="Sin correo" domain="[('email', '=', False)]"/>
                <filter name="missing_phone" string="Sin celular" domain="[('phone', '=', False)]"/>
                <separator/>
                <filter name="id_cedula" string="Cedula" domain="[('id_type', '=', 'cedula')]"/>
                <filter name="id_passport" string="Pasaporte" domain="[('id_type', '=', 'passport')]"/>
                <filter name="id_ruc_natural" string="RUC persona natural" domain="[('id_type', '=', 'ruc_natural')]"/>
                <filter name="id_ruc_juridica" string="RUC juridica" domain="[('id_type', '=', 'ruc_juridica')]"/>
                <group name="group_by">
                    <filter name="group_advisor" string="Asesor" context="{'group_by': 'user_id'}"/>
                    <filter name="group_id_type" string="Tipo de identificacion" context="{'group_by': 'id_type'}"/>
                    <filter name="group_state" string="Provincia" context="{'group_by': 'state_id'}"/>
                    <filter name="group_country" string="Pais" context="{'group_by': 'country_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_insurance_clients" model="ir.actions.act_window">
        <field name="name">Clientes</field>
        <field name="res_model">insurance.client</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0), (0, 0, {'view_mode': 'list', 'view_id': ref('view_insurance_client_list')}), (0, 0, {'view_mode': 'form', 'view_id': ref('view_insurance_client_form')})]"/>
        <field name="search_view_id" ref="view_insurance_client_search"/>
        <field name="domain">[]</field>
        <field name="context">{'default_company_type': 'person'}</field>
    </record>

    <menuitem id="menu_insurance_clients" name="Clientes" parent="insurance_base.menu_insurance_root" action="action_insurance_clients" sequence="10"/>
</odoo>
